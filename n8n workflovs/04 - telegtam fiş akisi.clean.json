    {
      "parameters": {
        "method": "POST",
        "url": "https://vision.googleapis.com/v1/images:annotate?key=AIzaSyBltZRduPsCwMxqTP1-AwQqBHvS2fHjHt4",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"requests\": [\n    {\n      \"image\": { \"content\": \"{{ $('Dosyayi Hazirla').first().json.base64Image }}\" },\n      \"features\": [\n        { \"type\": \"TEXT_DETECTION\" },\n        { \"type\": \"DOCUMENT_TEXT_DETECTION\", \"maxResults\": 1 }\n      ]\n    }\n  ]\n}"
      },
      "id": "vision-node",
      "name": "Google Vision OCR",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1650,
        -90
      ]
    },
    {
      "parameters": {
        "jsCode": "const txt = $json.responses?.[0]?.textAnnotations?.[0]?.description || '';\nif (!txt || txt.trim().length < 10) return [{ json: { isFis: false, reason: 'Yazi okunamadi', text: txt } }];\nconst low = txt.toLowerCase();\nconst keywords = ['kdv','toplam','tutar','fis','fatura','odeme','kart','nakit','tarih','matrah','vergi'];\nconst hits = keywords.filter((k) => low.includes(k)).length;\nconst hasNumbers = /\\d+[.,]?\\d*/.test(low);\nreturn [{ json: { isFis: hits >= 2 && hasNumbers, reason: hits >= 2 && hasNumbers ? 'OK' : 'Fis kriterlerine uymuyor', text: txt } }];"
      },
