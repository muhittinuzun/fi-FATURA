        "binaryPropertyName": "image",
        "fileName": "={{ `${$('Kullanici ve Sirket Kontrolu').first().json.company_id}/${$('Kullanici ve Sirket Kontrolu').first().json.company_name}/fisler/${$now.format('yyyy/MM')}/${$('Dosyayi Hazirla').first().json.fileName}` }}"
