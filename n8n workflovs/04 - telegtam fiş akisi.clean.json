      "credentials": {
        "googlePalmApi": {
          "id": "mg6Qkierq2X8bX9f",
          "name": "DEMOPROJE"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const raw = $json.content || $json.text || $json.output || JSON.stringify($json);\nlet obj = null;\nif (typeof raw === 'string') {\n  const cleaned = raw.replace(/```json|```/g, '').trim();\n  obj = JSON.parse(cleaned);\n} else if (typeof raw === 'object') {\n  obj = raw;\n}\nif (!obj || typeof obj !== 'object') throw new Error('Gemini JSON parse edilemedi');\nconst details = Array.isArray(obj.UrunlerVeKDVBilgileri) ? obj.UrunlerVeKDVBilgileri.map((x) => ({ aciklama: x.Aciklama || '', kategori: x.Kategori || '', kdv_oran: Number(x.KDVOrani || 0), matrah: Number(x.Matrah || 0), kdv_tutar: Number(x.KDVTutari || 0), tutar: Number(x.Tutar_KDVDahil || 0) })) : [];\nreturn [{ json: { isletme_adi: obj.IsletmeAdi || '', tarih: obj.Tarih || null, saat: obj.Saat || null, fis_no: obj.FisNumarasi || '', toplam_tutar: Number(obj.ToplamTutar || 0), odeme_tipi: obj.OdemeTipi || '', kart_son_4: obj.KartSon4Hane || '', kategori: details[0]?.kategori || 'Diger', ocr_detaylari: details } }];"
      },
