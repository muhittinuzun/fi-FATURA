    {
      "parameters": {
        "jsCode": "const src = $('Telegram Gelen Mesaj').first();\nconst binary = src.binary || {};\nconst keys = Object.keys(binary);\nif (!keys.length) throw new Error('Gorsel bulunamadi');\nconst k = keys[0];\nconst image = binary[k];\nconst ext = (image.fileExtension || 'jpg').replace('.', '');\nconst fileName = `${src.json.message.chat.id}_${Date.now()}.${ext}`;\nreturn [{ json: { chat_id: src.json.message.chat.id, fileName, base64Image: image.data }, binary: { image } }];"
      },
