    {
      "parameters": {
        "jsCode": "const cats = $input.all().map((i) => i.json.name).filter(Boolean);\nconst catList = cats.length ? cats : ['Market', 'Yemek', 'Yakit', 'Diger'];\nconst ocrText = $('Fis Dogrulama').first().json.text || '';\nconst prompt = `Asagidaki OCR metnini analiz et ve sadece gecerli JSON dondur.\\nKategori secenekleri: ${catList.join(', ')}\\n\\nOCR:\\n${ocrText}`;\nconst schema = { IsletmeAdi: 'string', Tarih: 'string', Saat: 'string', FisNumarasi: 'string', ToplamTutar: 'number', OdemeTipi: 'string', KartSon4Hane: 'string', UrunlerVeKDVBilgileri: [{ Aciklama: 'string', Kategori: 'string', KDVOrani: 'number', Matrah: 'number', KDVTutari: 'number', Tutar_KDVDahil: 'number' }] };\nreturn [{ json: { user_prompt: prompt, system_prompt: `Yalnizca JSON dondur. Beklenen sema: ${JSON.stringify(schema)}` } }];"
      },
      "id": "prompt-node",
      "name": "Prompt Hazirla",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2590,
        -230
      ]
    },
    {
      "parameters": {
        "modelId": {
          "value": "models/gemini-2.5-flash",
          "mode": "list"
        },
        "messages": {
          "values": [
            {
              "content": "={{ $json.user_prompt }}"
            }
          ]
        },
        "jsonOutput": true,
        "options": {
