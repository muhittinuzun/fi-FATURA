    {
      "parameters": {
        "jsCode": "const cats = $input.all().map((i) => i.json.name).filter(Boolean);\nconst catList = cats.length ? cats : ['Market', 'Yemek', 'Yakit', 'Diger'];\nconst ocrText = $('Fis Dogrulama').first().json.text || '';\nconst prompt = `Asagidaki OCR metnini analiz et ve sadece gecerli JSON dondur.\\nKategori secenekleri: ${catList.join(', ')}\\n\\nOCR:\\n${ocrText}`;\nconst schema = {\n  IsletmeAdi: 'string',\n  Tarih: 'string',\n  Saat: 'string',\n  FisNumarasi: 'string',\n  ToplamTutar: 'number',\n  OdemeTipi: 'string',\n  KartSon4Hane: 'string',\n  UrunlerVeKDVBilgileri: [\n    {\n      Aciklama: 'string',\n      Kategori: 'string',\n      KDVOrani: 'number',\n      Matrah: 'number',\n      KDVTutari: 'number',\n      Tutar_KDVDahil: 'number'\n    }\n  ]\n};\nreturn [{ json: { user_prompt: prompt, system_prompt: `Yalnizca JSON dondur. Beklenen sema: ${JSON.stringify(schema)}` } }];"
      },
      "id": "prompt-node",
      "name": "Prompt Hazirla",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2580,
        -220
      ]
    },
    {
      "parameters": {
        "modelId": {
          "value": "models/gemini-2.5-flash",
          "mode": "list"
        },
        "messages": {
          "values": [
            {
              "content": "={{ $json.user_prompt }}"
            }
          ]
        },
        "jsonOutput": true,
        "options": {
          "systemMessage": "={{ $json.system_prompt }}",
          "temperature": 0
        }
      },
      "id": "gemini-node",
      "name": "Gemini Analiz",
      "type": "@n8n/n8n-nodes-langchain.googleGemini",
      "typeVersion": 1,
      "position": [
        2820,
        -220
      ],
      "credentials": {
        "googlePalmApi": {
          "id": "mg6Qkierq2X8bX9f",
          "name": "DEMOPROJE"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const raw = $json.content || $json.text || $json.output || JSON.stringify($json);\nlet obj = null;\nif (typeof raw === 'string') {\n  const cleaned = raw.replace(/```json|```/g, '').trim();\n  obj = JSON.parse(cleaned);\n} else if (typeof raw === 'object') {\n  obj = raw;\n}\nif (!obj || typeof obj !== 'object') throw new Error('Gemini JSON parse edilemedi');\nconst details = Array.isArray(obj.UrunlerVeKDVBilgileri) ? obj.UrunlerVeKDVBilgileri.map((x) => ({\n  aciklama: x.Aciklama || '',\n  kategori: x.Kategori || '',\n  kdv_oran: Number(x.KDVOrani || 0),\n  matrah: Number(x.Matrah || 0),\n  kdv_tutar: Number(x.KDVTutari || 0),\n  tutar: Number(x.Tutar_KDVDahil || 0)\n})) : [];\nreturn [{ json: {\n  isletme_adi: obj.IsletmeAdi || '',\n  tarih: obj.Tarih || null,\n  saat: obj.Saat || null,\n  fis_no: obj.FisNumarasi || '',\n  toplam_tutar: Number(obj.ToplamTutar || 0),\n  odeme_tipi: obj.OdemeTipi || '',\n  kart_son_4: obj.KartSon4Hane || '',\n  kategori: details[0]?.kategori || 'Diger',\n  ocr_detaylari: details\n} }];"
      },
      "id": "parse-node",
      "name": "Gemini Cevap Parse",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3060,
        -220
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO fisler (company_id, user_id, isletme_adi, tarih, saat, fis_no, toplam_tutar, para_birimi, kart_son_4, odeme_tipi, kategori, proje, gorsel_url, ocr_detaylari, durum, created_at) VALUES ($1, $2, $3, NULLIF($4, '')::date, NULLIF($5, '')::time, $6, $7, 'TRY', NULLIF($8, ''), $9, $10, NULL, $11, $12::jsonb, 'beklemede', now()) RETURNING id;",
        "options": {
          "queryReplacement": "={{ [\n+            $('Kullanici ve Sirket Kontrolu').first().json.company_id,\n+            $('Kullanici ve Sirket Kontrolu').first().json.id,\n+            $json.isletme_adi,\n+            $json.tarih,\n+            $json.saat,\n+            $json.fis_no,\n+            $json.toplam_tutar,\n+            $json.kart_son_4,\n+            $json.odeme_tipi,\n+            $json.kategori,\n+            `https://cdn.fisfatura.com/${$('Kullanici ve Sirket Kontrolu').first().json.company_id}/${$('Kullanici ve Sirket Kontrolu').first().json.company_name}/fisler/${$now.format('yyyy/MM')}/${$('Dosyayi Hazirla').first().json.fileName}`,\n+            JSON.stringify($json.ocr_detaylari || [])\n+          ] }}"
        }
      },
