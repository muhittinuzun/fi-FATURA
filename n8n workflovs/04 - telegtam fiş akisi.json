    {
      "parameters": {
        "method": "POST",
        "url": "https://vision.googleapis.com/v1/images:annotate?key=AIzaSyBltZRduPsCwMxqTP1-AwQqBHvS2fHjHt4",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"requests\": [\n    {\n      \"image\": { \"content\": \"{{ $('Dosyayi Hazirla').first().json.base64Image }}\" },\n      \"features\": [\n        { \"type\": \"TEXT_DETECTION\" },\n        { \"type\": \"DOCUMENT_TEXT_DETECTION\", \"maxResults\": 1 }\n      ]\n    }\n  ]\n}"
      },
      "id": "vision-node",
      "name": "Google Vision OCR",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1640,
        -80
      ]
    },
    {
      "parameters": {
        "jsCode": "const ocrResult = $json.responses?.[0]?.textAnnotations?.[0]?.description || '';\nif (!ocrResult || ocrResult.trim().length < 10) {\n  return [{ json: { isFis: false, reason: 'Yazi okunamadi', text: ocrResult } }];\n}\nconst text = ocrResult.toLowerCase();\nconst keywords = ['kdv','toplam','tutar','fis','fatura','odeme','kart','nakit','tarih','matrah','vergi'];\nconst hasNumbers = /\\d+[.,]?\\d*/.test(text);\nconst keywordCount = keywords.filter((k) => text.includes(k)).length;\nconst isFis = keywordCount >= 2 && hasNumbers;\nreturn [{ json: { isFis, reason: isFis ? 'OK' : 'Fis kriterlerine uymuyor', text: ocrResult } }];"
      },
      "id": "fis-check",
      "name": "Fis Dogrulama",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1880,
        -80
      ]
