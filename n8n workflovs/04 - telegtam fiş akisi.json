    {
      "parameters": {
        "jsCode": "const src = $('Telegram Gelen Mesaj').first();\nconst bin = src.binary || {};\nconst keys = Object.keys(bin);\nif (!keys.length) throw new Error('Gorsel bulunamadi');\nconst first = keys[0];\nconst imageBinary = bin[first];\nconst base64Image = imageBinary.data;\nconst fileExt = (imageBinary.fileExtension || 'jpg').replace('.', '');\nconst fileName = `${src.json.message.chat.id}_${Date.now()}.${fileExt}`;\nreturn [{\n  json: {\n    chat_id: src.json.message.chat.id,\n    fileName,\n    base64Image\n  },\n  binary: {\n    image: imageBinary\n  }\n}];"
      },
