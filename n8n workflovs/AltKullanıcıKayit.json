        {
            "parameters": {
                "jsCode": "// 1. Webhook'tan gelen veriyi al\nlet body = $input.first().json.body || {};\n\n// 2. 'no-cors' modunda veri bazen string (metin) olarak gelir.\n// Eğer string ise JSON'a çeviriyoruz.\nif (typeof body === 'string') {\n    try {\n        body = JSON.parse(body);\n    } catch (e) {\n        console.log(\"JSON Parse Hatası:\", e);\n        body = {};\n    }\n}\n\n// 3. İsim Ayıklama (Ad Soyad birleşik gelirse ayır)\nlet firstName = body.Adınız || body.first_name || \"\";\nlet lastName = body.Soyadınız || body.last_name || \"\";\n\nif (!firstName && body.full_name) {\n    const parts = body.full_name.split(' ');\n    if (parts.length > 1) {\n        lastName = parts.pop();\n        firstName = parts.join(' ');\n    } else {\n        firstName = body.full_name;\n    }\n}\n\n// 4. Verileri hazırla ve sonraki düğümlere aktar\nreturn {\n    json: {\n        company_id: body.company_id,\n        email: body.email,\n        full_name: body.full_name || `${firstName} ${lastName}`.trim(),\n        first_name: firstName,\n        last_name: lastName,\n        // Şifre boş gelirse rastgele bir şifre ata\n        password: body.password || Math.random().toString(36).slice(-8), \n        role: body.role || 'user',\n        phone: body.phone || '',\n        manager_id: body.manager_id\n    }\n};"
            },
