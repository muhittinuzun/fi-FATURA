                "message": "=<div style=\"font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f9f9fa; padding: 40px 20px; color: #333;\">\n  <div style=\"max-width: 600px; margin: 0 auto; background-color: #ffffff; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); overflow: hidden;\">\n    \n    <!-- Başlık -->\n    <div style=\"background: linear-gradient(135deg, #4F46E5 0%, #3730A3 100%); padding: 30px; text-align: center;\">\n      <h1 style=\"color: #ffffff; margin: 0; font-size: 24px; letter-spacing: 1px; font-weight: 600;\">Fiş Fatura</h1>\n    </div>\n\n    <!-- İçerik -->\n    <div style=\"padding: 40px 30px;\">\n      <h2 style=\"color: #1f2937; font-size: 22px; margin-top: 0; margin-bottom: 20px;\">Aramıza Hoş Geldiniz! 🎉</h2>\n      \n      <p style=\"font-size: 16px; line-height: 1.6; color: #4b5563; margin-bottom: 15px;\">\n        Merhaba Sayın <strong>{{ $('Code (Veri Hazırla)').first().json.full_name }}</strong>,\n      </p>\n      \n      <p style=\"font-size: 16px; line-height: 1.6; color: #4b5563;\">\n        Fiş Fatura hesabınız şirket yöneticiniz tarafından oluşturulmuştur. Giriş bilgileriniz aşağıdadır.\n      </p>\n\n      <!-- Hesap Bilgileri Kutusu -->\n      <div style=\"background-color: #eff6ff; border-left: 4px solid #4F46E5; padding: 25px; margin: 30px 0; border-radius: 4px;\">\n        <h3 style=\"margin-top: 0; margin-bottom: 15px; color: #3730A3; font-size: 16px;\">Giriş Bilgileriniz</h3>\n        \n        <div style=\"margin-bottom: 15px;\">\n          <p style=\"margin: 0; color: #6b7280; font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px;\">E-Posta</p>\n          <p style=\"margin: 4px 0 0 0; color: #1f2937; font-size: 16px; font-weight: 600;\">{{ $('Code (Veri Hazırla)').first().json.email }}</p>\n        </div>\n\n        <div>\n          <p style=\"margin: 0; color: #6b7280; font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px;\">Şifreniz</p>\n          <p style=\"margin: 4px 0 0 0; color: #4F46E5; font-size: 20px; font-weight: 700; font-family: 'Courier New', monospace; letter-spacing: 1px;\">\n             {{ $('Code (Veri Hazırla)').first().json.password }}\n          </p>\n        </div>\n      </div>\n      \n      <!-- Telegram Bot Yönlendirmesi (YENİ) -->\n      <div style=\"background-color: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 8px; padding: 20px; margin-bottom: 30px; text-align: center;\">\n        <h3 style=\"margin: 0 0 10px 0; color: #15803d; font-size: 18px;\">📱 Fiş Göndermeye Başlayın</h3>\n        <p style=\"margin: 0 0 15px 0; font-size: 14px; color: #166534;\">\n            Fiş fotoğraflarınızı Telegram botumuza göndererek sisteme anında işleyebilirsiniz.\n        </p>\n        <a href=\"https://t.me/ITT_Fis_matik_BOT\" target=\"_blank\" style=\"display: inline-flex; align-items: center; gap: 8px; background-color: #22c55e; color: #ffffff; text-decoration: none; padding: 10px 20px; border-radius: 6px; font-weight: 600; font-size: 14px;\">\n            Telegram Botunu Başlat\n        </a>\n      </div>\n\n      <div style=\"text-align: center; margin: 35px 0;\">\n        <a href=\"https://muhittinuzun.github.io/FismatikMusteriPaneli/\" style=\"background-color: #4F46E5; color: #ffffff; text-decoration: none; padding: 14px 35px; border-radius: 8px; font-weight: 600; display: inline-block; box-shadow: 0 4px 6px rgba(79, 70, 229, 0.2);\">Panele Giriş Yap</a>\n      </div>\n\n      <p style=\"font-size: 14px; color: #6b7280; margin-top: 30px; border-top: 1px solid #e5e7eb; padding-top: 20px;\">\n        <strong>Not:</strong> Güvenliğiniz için giriş yaptıktan sonra <em>Ayarlar</em> menüsünden şifrenizi değiştirmenizi öneririz.\n      </p>\n    </div>\n\n    <!-- Alt Bilgi -->\n    <div style=\"background-color: #f3f4f6; padding: 20px; text-align: center;\">\n      <p style=\"margin: 0; font-size: 12px; color: #9ca3af;\">\n        © 2025 Fiş Fatura. Tüm hakları saklıdır.\n      </p>\n    </div>\n